#!/usr/bin/env bash
set -euo pipefail

INPUT="$(cat || true)"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
AUTHORIZED_FILES_PATH="$SCRIPT_DIR/authorized-files.json"
export HOOK_INPUT="$INPUT"
export AUTHORIZED_FILES_PATH

node <<'NODE'
const fs = require("node:fs");
const path = require("node:path");

const raw = process.env.HOOK_INPUT || "";

let authorizedGlobs;
try {
  authorizedGlobs = JSON.parse(fs.readFileSync(process.env.AUTHORIZED_FILES_PATH, "utf-8"));
} catch {
  // If we cannot read the allowlist, deny everything.
  console.error("Blocked: could not read authorized-files.json");
  process.exit(1);
}

if (!Array.isArray(authorizedGlobs) || authorizedGlobs.length === 0) {
  process.exit(0);
}

let payload;
try {
  payload = JSON.parse(raw);
} catch {
  process.exit(0);
}

// Deny shell_exec by default unless authorized globs explicitly include "shell:allow"
const toolName = typeof payload.tool_name === "string" ? payload.tool_name : "";
const shellAllowed = authorizedGlobs.some((g) => String(g) === "shell:allow");
if (toolName === "shell_exec" && !shellAllowed) {
  console.error("Blocked: shell_exec is denied by default.");
  console.error("Add \"shell:allow\" to authorized_files to permit shell commands.");
  process.exit(1);
}

const filePaths = [];
collectPaths(payload, "", filePaths);
if (filePaths.length === 0) {
  process.exit(0);
}

const unauthorized = [];
for (const filePath of filePaths) {
  const normalized = normalizePath(filePath);
  if (!normalized) continue;
  const allowed = authorizedGlobs.some((glob) => globMatches(normalized, String(glob)));
  if (!allowed) unauthorized.push(normalized);
}

if (unauthorized.length > 0) {
  console.error("Blocked unauthorized file access:");
  for (const filePath of unauthorized) {
    console.error(`- ${filePath}`);
  }
  console.error(`Allowed globs: ${authorizedGlobs.join(", ")}`);
  process.exit(1);
}

function collectPaths(value, keyHint, out) {
  if (!value) return;
  if (Array.isArray(value)) {
    for (const item of value) collectPaths(item, keyHint, out);
    return;
  }

  if (typeof value === "object") {
    for (const [key, nested] of Object.entries(value)) {
      collectPaths(nested, key, out);
    }
    return;
  }

  if (
    typeof value === "string" &&
    /(file|path)/i.test(keyHint) &&
    value.trim() !== "" &&
    !value.includes("\n")
  ) {
    out.push(value.trim());
  }
}

function normalizePath(candidate) {
  if (!candidate || candidate.startsWith("http://") || candidate.startsWith("https://")) {
    return "";
  }
  const cwd = process.cwd();
  const absolute = path.isAbsolute(candidate) ? candidate : path.resolve(cwd, candidate);
  const relative = path.relative(cwd, absolute).replace(/\\/g, "/");
  if (relative.startsWith("..")) return "";
  return relative.replace(/^\.\//, "");
}

function globMatches(filePath, glob) {
  const regex = globToRegex(glob);
  return regex.test(filePath);
}

function globToRegex(glob) {
  let pattern = "^";
  for (let i = 0; i < glob.length; i++) {
    const ch = glob[i];
    const next = glob[i + 1];
    if (ch === "*") {
      if (next === "*") {
        // ** matches everything including path separators
        pattern += ".*";
        i++;
        // Skip trailing slash after ** (e.g., **/)
        if (glob[i + 1] === "/") i++;
      } else {
        // * matches anything except /
        pattern += "[^/]*";
      }
      continue;
    }
    if (ch === "?") {
      pattern += "[^/]";
      continue;
    }
    if ("\\.[]{}()+-^$|".includes(ch)) {
      pattern += `\\${ch}`;
    } else {
      pattern += ch;
    }
  }
  pattern += "$";
  return new RegExp(pattern);
}
NODE
